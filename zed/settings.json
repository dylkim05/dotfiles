{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "new_window",
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "format_on_save": "on",
  "show_edit_predictions": false,
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "low",
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "icon_theme": "Catppuccin Macchiato",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Zedokai (Filter Octagon)",
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_size": 14,
  },
}
