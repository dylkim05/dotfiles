[
  {
    "context": "Dock || Terminal || Editor && VimControl && vim_mode != insert",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-q": "pane::CloseActiveItem",
      "ctrl-o": "pane::ActivateNextItem",
      "ctrl-i": "pane::ActivatePreviousItem",
    },
  },
  {
    "context": "GitPanel || GitPanel > Editor && VimControl && !VimWaiting && vim_mode != insert",
    "bindings": {
      // focus
      "space f c": "git_panel::FocusChanges",
      "space f m": "git_panel::FocusEditor",
      "space q": "git_panel::Close",

      // git actions
      "space g p": "git::Push",
      "space g shift-p": "git::Pull",
      "space g shift-s": "git::Switch",
      "space g c": "git::Commit",
      "space g c m": "git::GenerateCommitMessage",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      // file operations
      "n f": "project_panel::NewFile",
      "n d": "project_panel::NewDirectory",
      "d": "project_panel::Delete",
      "r": "project_panel::Rename",

      // close
      "space q": "project_panel::Toggle",
    },
  },
  {
    // empty pane
    "context": "EmptyPane",
    "bindings": {
      "space q w": "pane::CloseActiveItem",
      "space q z": "zed::Quit",
      "space n f": "workspace::NewFile",
      "space o p": "projects::OpenRecent",
      "space s p": "workspace::NewSearch",

      // toggling docks
      "space l": "workspace::ToggleLeftDock",
      "space r": "workspace::ToggleRightDock",
      "space b": "workspace::ToggleBottomDock",

      // focus panels
      "space g g": "git_panel::ToggleFocus",
      "space t": "workspace::NewCenterTerminal",
      "space p p": "project_panel::ToggleFocus",
      "space c p": "command_palette::Toggle",
      "space space": "file_finder::Toggle",

      // agent
      "space a a": "agent::ToggleFocus",
      "space n t": "agent::NewThread",

      // git actions
      "space g p": "git::Push",
      "space g shift-p": "git::Pull",
      "space g s": "git::Switch",
    },
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu && vim_mode != insert",
    "bindings": {
      // close pane
      "space q w": "pane::CloseActiveItem",
      "space q a": "pane::CloseAllItems",

      // projects
      "space o p": "projects::OpenRecent",
      "space s p": "workspace::NewSearch",

      // workspace
      "space o w": "workspace::NewWindow",

      // search file
      "space s f": "buffer_search::DeployReplace",

      // window splitting
      "space s v": "pane::SplitVertical",
      "space s h": "pane::SplitHorizontal",

      // toggling docks
      "space l": "workspace::ToggleLeftDock",
      "space r": "workspace::ToggleRightDock",
      "space b": "workspace::ToggleBottomDock",

      // focus panels
      "space g g": "git_panel::ToggleFocus",
      "space t": "workspace::NewCenterTerminal",
      "space p p": "project_panel::ToggleFocus",
      "space c p": "command_palette::Toggle",
      "space space": "file_finder::Toggle",

      // git actions
      "space g p": "git::Push",
      "space g shift-p": "git::Pull",
      "space g s": "git::Switch",

      // tab navigation
      "g T": "pane::ActivatePreviousItem",
      "g t": "pane::ActivateNextItem",

      // diagnostics
      "space x x": "diagnostics::Deploy",
      "]d": "editor::GoToDiagnostic",
      "[d": "editor::GoToPreviousDiagnostic",

      // git hunks
      "]h": "editor::GoToHunk",
      "[h": "editor::GoToPreviousHunk",

      // lsp
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c R": "editor::FindAllReferences",
      "space c f": "editor::Format",
      "space d": "editor::GoToDefinition",
      "space t d": "editor::GoToTypeDefinition",
      "K": "editor::Hover",

      // symbols
      "space s s": "outline::Toggle",
      "space s S": "project_symbols::Toggle",

      // zoom active pane
      "space z": "workspace::ToggleZoom",

      // agent
      "space a a": "agent::ToggleFocus",
      "space n t": "agent::NewThread",
    },
  },
  {
    "context": "AgentPanel || AgentPanel > Editor && VimControl && !VimWaiting && vim_mode != insert",
    "bindings": {
      // close
      "space q": "workspace::ToggleRightDock",

      // toggling docks
      "space l": "workspace::ToggleLeftDock",
      "space r": "workspace::ToggleRightDock",
      "space b": "workspace::ToggleBottomDock",

      // agent
      "space n t": "agent::NewThread",
    },
  },
]
